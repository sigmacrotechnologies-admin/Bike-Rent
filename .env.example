# ===========================================
# Velocity Rent - Environment Configuration
# ===========================================

# Application
NODE_ENV=development
APP_NAME=VelocityRent
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
API_VERSION=v1

# Backend
PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB (local dev)
MONGODB_URI=mongodb://localhost:27017/velocity_rent
# MongoDB Atlas (production) — use /velocity_rent as database name, no spaces in URI
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/velocity_rent?retryWrites=true&w=majority
MONGODB_URI_TEST=mongodb://localhost:27017/velocity_rent_test

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redis (optional - for caching/sessions)
REDIS_URL=redis://localhost:6379

# GPS / Maps
GOOGLE_MAPS_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
